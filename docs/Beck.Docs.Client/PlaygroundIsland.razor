@* The interactive playground island: rendered in the browser (WebAssembly) inside the
   static-SSR /playground page (Components/Pages/Playground.razor in the host). Kept
   non-routable so the host's Pennington crawler owns the /playground route and emits it
   statically; this component just supplies the in-browser interactivity. *@
@rendermode InteractiveWebAssembly
@inject HttpClient Http
@inject IJSRuntime Js
@using Beck.Model
@using Beck.Text
@implements IDisposable

<div class="h-[calc(100vh-62px)] flex flex-col">
    <div class="flex items-center gap-3 px-5 py-[9px] border-b border-base-200 dark:border-base-800 bg-base-50 dark:bg-base-900">
        @* Examples: a rich grouped dropdown. Open/close/select are component state; each
           item fetches its sample's YAML from the site's /examples over HttpClient. *@
        <div id="pg-examples" class="pg-dd @(_open == Dd.Examples ? "is-open" : "")">
            <button type="button" class="pg-dd-trigger" @onclick="ToggleExamples" @onkeydown="e => OnTriggerKey(e, Dd.Examples)" aria-haspopup="listbox" aria-expanded="@(_open == Dd.Examples)">
                <span class="pg-dd-value">@_exampleLabel</span>
                <svg class="pg-dd-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </button>
            @if (_open == Dd.Examples)
            {
                <div class="pg-dd-panel" role="listbox" aria-label="Example diagrams">
                    @foreach (var group in ExampleGroups)
                    {
                        <div class="pg-dd-group">
                            <div class="pg-dd-group-label">@group.Label</div>
                            @foreach (var ex in group.Items)
                            {
                                <button type="button" class="pg-dd-item" role="option" @onclick="() => LoadExample(ex)" @onkeydown="e => OnOptionKey(e, Dd.Examples)">
                                    <span class="pg-dd-item-main">
                                        <span class="pg-dd-item-title">@ex.Label</span>
                                        <span class="pg-dd-item-desc">@ex.Desc</span>
                                    </span>
                                    <span class="pg-pill" data-type="@group.Type">@group.Glyph @group.Short</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        @* Visual style: sets SvgRenderOptions.Style (the site-wide default). A diagram's own
           meta.style still wins — the documented precedence — so this is a default, not an
           override; the panel hints as much. Classic is first and is the default. Changing it
           rebuilds the options and re-renders. *@
        <div id="pg-style" class="pg-dd ml-auto @(_open == Dd.Style ? "is-open" : "")">
            <button type="button" class="pg-dd-trigger" @onclick="ToggleStyle" @onkeydown="e => OnTriggerKey(e, Dd.Style)" aria-haspopup="listbox" aria-expanded="@(_open == Dd.Style)" title="Default style — a diagram's meta.style overrides">
                <span class="pg-dd-trigger-label">Style</span>
                <span class="pg-dd-value">@_styleLabel</span>
                <svg class="pg-dd-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </button>
            @if (_open == Dd.Style)
            {
                <div class="pg-dd-panel pg-dd-panel--right" role="listbox" aria-label="Diagram style">
                    <div class="pg-dd-note">Default style — a diagram's <code>meta.style</code> overrides.</div>
                    @foreach (var st in Styles)
                    {
                        <button type="button" class="pg-dd-item pg-dd-item--scheme" role="option" aria-selected="@(_styleName == st.Name)" @onclick="() => SelectStyle(st)" @onkeydown="e => OnOptionKey(e, Dd.Style)">
                            <span class="pg-dd-item-main">
                                <span class="pg-dd-item-title">@st.Label</span>
                                <span class="pg-dd-item-desc">@st.Desc</span>
                            </span>
                        </button>
                    }
                </div>
            }
        </div>

        @* Colour scheme: recolours the live diagram by overriding its --beck-* tokens
           on #pg-host[data-scheme] (see BrandStyling). Pure CSS — setting the attribute is
           enough, no re-render. "Default" keeps the site palette and the light/dark toggle. *@
        <div id="pg-scheme" class="pg-dd @(_open == Dd.Scheme ? "is-open" : "")">
            <button type="button" class="pg-dd-trigger" @onclick="ToggleScheme" @onkeydown="e => OnTriggerKey(e, Dd.Scheme)" aria-haspopup="listbox" aria-expanded="@(_open == Dd.Scheme)">
                <span class="pg-swatch" data-scheme="@_scheme"></span>
                <span class="pg-dd-value">@_schemeLabel</span>
                <svg class="pg-dd-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </button>
            @if (_open == Dd.Scheme)
            {
                <div class="pg-dd-panel pg-dd-panel--right" role="listbox" aria-label="Colour scheme">
                    @foreach (var s in Schemes)
                    {
                        <button type="button" class="pg-dd-item pg-dd-item--scheme" role="option" aria-selected="@(_scheme == s.Value)" @onclick="() => SelectScheme(s)" @onkeydown="e => OnOptionKey(e, Dd.Scheme)">
                            <span class="pg-swatch" data-scheme="@s.Value"></span>
                            <span class="pg-dd-item-title">@s.Label</span>
                        </button>
                    }
                </div>
            }
        </div>
    </div>

    @* A transparent full-viewport layer so a click anywhere outside an open panel closes
       it. Sits below the panel (z-index) so panel items stay clickable. *@
    @if (_open != Dd.None)
    {
        <div class="pg-dd-backdrop" @onclick="CloseDropdowns"></div>
    }

    <div id="pg-panes" class="flex-1 grid grid-cols-2 min-h-0 max-md:grid-cols-1 max-md:grid-rows-2">
        <div class="flex flex-col min-h-0 border-r border-base-200 dark:border-base-800">
            <div class="flex items-center px-4 py-[7px] border-b border-base-200 dark:border-base-800 font-mono text-[11.5px] text-base-400 dark:text-base-500 bg-base-50 dark:bg-base-900">system.beck.yaml</div>
            @* Monaco editor (schema-aware YAML completions + hover, driven from C# off
               BeckSchema). Its container is sized by flex; the editor's automaticLayout
               tracks it. Before the WASM island boots this pane is empty — the prerendered
               chrome shows the frame only. *@
            <div id="pg-editor-host">
                <StandaloneCodeEditor @ref="_editor" Id="pg-monaco" CssClass="h-full"
                                      ConstructionOptions="EditorConstructionOptions"
                                      OnDidInit="EditorInit"
                                      OnDidChangeModelContent="EditorChanged" />
            </div>
        </div>
        <div class="flex flex-col min-h-0">
            <div class="flex items-center px-4 py-[7px] border-b border-base-200 dark:border-base-800 font-mono text-[11.5px] text-base-400 dark:text-base-500 bg-white dark:bg-base-950">
                preview
                <span class="inline-flex items-center gap-1.5 font-mono text-[11px] text-primary-700 dark:text-primary-400 ml-auto"><span class="h-[7px] w-[7px] rounded-full bg-primary-600 dark:bg-primary-400 animate-pulse"></span>live</span>
            </div>
            @* Center with the host's auto margins (see #pg-host in BrandStyling), not
               `items-center`: a flex item taller than this pane would be centered by
               `align-items:center` with its top pushed above the scroll origin (an
               unreachable clip). Auto margins center when there's room and collapse to
               the top on overflow, keeping the title scrollable. *@
            <div class="dot-grid flex-1 min-h-0 overflow-auto p-6 flex pg-preview-canvas">
                <div id="pg-host" class="w-full" data-scheme="@_scheme">
                    @if (_svg.Length > 0)
                    {
                        <div class="beck-embed">@((MarkupString)_svg)</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="flex items-center gap-4 px-5 py-[7px] border-t border-base-200 dark:border-base-800 bg-base-50 dark:bg-base-900 font-mono text-[11.5px] text-base-400 dark:text-base-500">
        <span id="pg-status" class="@(_ok ? "ok" : "err")">@_statusText</span>
        <span id="pg-nodes">@_nodeCount nodes</span>
        <span id="pg-edges">@_edgeCount edges</span>
        <span class="ml-auto">Rendered live by Beck</span>
    </div>
</div>

@code {
    // ---- editor + render state ----------------------------------------------
    private string _yaml = InitialYaml;
    private string _svg = "";
    private bool _ok = true;
    private string _statusText = "✓ valid";
    private int _nodeCount, _edgeCount;

    // ---- Monaco editor ------------------------------------------------------
    private StandaloneCodeEditor _editor = null!;
    private string _editorTheme = "beck";
    // Programmatic SetValue (example load) fires OnDidChangeModelContent; swallow that one
    // event so it doesn't schedule a second, animation-restarting render after our explicit one.
    private bool _suppressNextChange;
    private DotNetObjectReference<PlaygroundIsland>? _hostRef;

    // Debounce the live re-render: typing fires oninput per keystroke, but a full
    // layout+route+SVG pass (and its restarting animation) shouldn't run mid-word.
    private CancellationTokenSource? _debounce;

    // ---- toolbar state ------------------------------------------------------
    private enum Dd { None, Examples, Style, Scheme }
    private Dd _open = Dd.None;
    private string _exampleLabel = "Load an example…";
    private string _scheme = "default";
    private string _schemeLabel = "Default";
    // The site-wide default style (SvgRenderOptions.Style). Classic by default; a diagram's
    // own meta.style still wins over this (see SelectStyle / BuildOptions).
    private BeckStyle _style = BeckStyle.Classic;
    private string _styleName = BeckStyle.Classic.Name;
    private string _styleLabel = "Classic";

    // Ask for the site's IBM Plex families (rewrites --beck-font); glyphs are measured in the
    // browser via canvas measureText (CanvasTextMeasurer), so card sizing matches exactly what
    // the browser draws. Measurer is wired up on the first client render (below).
    private static readonly BeckFontSpec Font = new()
    {
        Family = "IBM Plex Sans",
        MonoFamily = "IBM Plex Mono",
        Files = new Dictionary<int, string>(),
    };
    private ITextMeasurer? _measurer;
    private SvgRenderOptions? _options;

    // The canvas measurer + the selected style folded into the render options. Rebuilt whenever
    // the style default changes (SvgRenderOptions is init-only). Style is the lowest-precedence
    // default: a diagram's own meta.style resolves over it inside BeckSvg.
    private SvgRenderOptions BuildOptions() =>
        new() { Font = Font, Measurer = _measurer!, Style = _style };

    // Render only happens in the browser: measurement needs canvas, which doesn't exist during
    // server prerender. Prerender emits the chrome (toolbar/editor); the diagram appears once
    // WASM boots, the shim is present, and the IBM Plex faces have loaded.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _measurer = new CanvasTextMeasurer((IJSInProcessRuntime)Js);
            _options = BuildOptions();
            await Js.InvokeVoidAsync("beckMeasure.fontsReady");
            RenderNow();
            StateHasChanged();
            // The island has activated and painted: disarm the boot watchdog in
            // beck-editor.js so its "WebAssembly is blocked" notice never shows.
            await Js.InvokeVoidAsync("beckEditor.ready");
            return;
        }
        // A dropdown was just opened by keyboard: move focus into its option list.
        if (_focusDdOnRender is { } id)
        {
            _focusDdOnRender = null;
            await Js.InvokeVoidAsync("beckEditor.focusDdOption", id, 0);
        }
    }

    // The editor's initial content + language come from ConstructionOptions; the theme is set
    // in EditorInit once the beck themes are defined (below).
    private StandaloneEditorConstructionOptions EditorConstructionOptions(StandaloneCodeEditor _) => new()
    {
        Language = "yaml",
        Value = _yaml,
        Theme = _editorTheme,
        AutomaticLayout = true,
        Minimap = new EditorMinimapOptions { Enabled = false },
        ScrollBeyondLastLine = false,
        FontFamily = "'IBM Plex Mono', ui-monospace, monospace",
        LineHeight = 24,
        WordWrap = "off",
        LineNumbers = "on",
        RenderLineHighlight = "line",
        Padding = new EditorPaddingOptions { Top = 14, Bottom = 14 },
    };

    // Runs once the Monaco instance exists: define the brand themes, register schema-aware
    // completions/hover, and hook the site theme toggle so the editor recolours with the page.
    private async Task EditorInit()
    {
        await DefineThemesAsync();
        await BeckCompletions.RegisterAsync(Js);

        _hostRef = DotNetObjectReference.Create(this);
        var theme = await Js.InvokeAsync<string>("beckEditor.observeTheme", _hostRef);
        _editorTheme = theme == "dark" ? "beck-dark" : "beck";
        await BlazorMonaco.Editor.Global.SetTheme(Js, _editorTheme);

        // Arriving here via an enhanced-navigation link click can leave Monaco created but
        // never painted (see beckEditor.nudge). Kick the render once the editor exists.
        await Js.InvokeVoidAsync("beckEditor.nudge");
    }

    // Live edits: mirror the editor value into _yaml and re-render (debounced). The single
    // programmatic SetValue from LoadExample is swallowed here so it renders exactly once.
    private async Task EditorChanged(ModelContentChangedEvent _)
    {
        if (_suppressNextChange) { _suppressNextChange = false; return; }
        _yaml = await _editor.GetValue();
        await ScheduleRender();
    }

    // Called from beck-editor.js when the site theme toggles; flip the editor between the
    // light and dark brand themes to match.
    [JSInvokable]
    public async Task OnHostThemeChanged(string theme)
    {
        _editorTheme = theme == "dark" ? "beck-dark" : "beck";
        await BlazorMonaco.Editor.Global.SetTheme(Js, _editorTheme);
    }

    // Two brand-tinted Monaco themes (Monaco needs literal colours, so these can't ride the
    // site's CSS variables). Slate neutrals + an emerald key colour echo the Beck palette;
    // beck-editor.js flips between them on the site theme toggle.
    private async Task DefineThemesAsync()
    {
        static List<TokenThemeRule> Rules(string key, string str, string num, string comment) =>
        [
            new() { Token = "type", Foreground = key },
            new() { Token = "key", Foreground = key },
            new() { Token = "string.yaml", Foreground = str },
            new() { Token = "string", Foreground = str },
            new() { Token = "number", Foreground = num },
            new() { Token = "comment", Foreground = comment, FontStyle = "italic" }
        ];

        await BlazorMonaco.Editor.Global.DefineTheme(Js, "beck", new StandaloneThemeData
        {
            Base = "vs",
            Inherit = true,
            Rules = Rules("047857", "0369a1", "b45309", "94a3b8"),
            Colors = new Dictionary<string, string>
            {
                ["editor.background"] = "#f8fafc",
                ["editor.foreground"] = "#334155",
                ["editorLineNumber.foreground"] = "#cbd5e1",
                ["editorLineNumber.activeForeground"] = "#64748b",
                ["editor.lineHighlightBackground"] = "#eef2f6",
                ["editor.selectionBackground"] = "#d1fae5",
                ["editorCursor.foreground"] = "#047857",
            },
        });

        await BlazorMonaco.Editor.Global.DefineTheme(Js, "beck-dark", new StandaloneThemeData
        {
            Base = "vs-dark",
            Inherit = true,
            Rules = Rules("34d399", "38bdf8", "fbbf24", "64748b"),
            Colors = new Dictionary<string, string>
            {
                ["editor.background"] = "#0f172a",
                ["editor.foreground"] = "#e2e8f0",
                ["editorLineNumber.foreground"] = "#334155",
                ["editorLineNumber.activeForeground"] = "#94a3b8",
                ["editor.lineHighlightBackground"] = "#111c33",
                ["editor.selectionBackground"] = "#134e4a",
                ["editorCursor.foreground"] = "#34d399",
            },
        });
    }

    // Debounced editor render. @bind:after fires after each oninput has updated _yaml;
    // we then wait out a quiet window before the (relatively expensive) render.
    private async Task ScheduleRender()
    {
        _debounce?.Cancel();
        _debounce?.Dispose();
        var cts = _debounce = new CancellationTokenSource();
        try { await Task.Delay(250, cts.Token); }
        catch (OperationCanceledException) { return; }
        RenderNow();
    }

    // Render _yaml to SVG in the browser. On a bad document keep the last good diagram
    // (matching the old JS playground) and surface the error in the status bar only.
    private void RenderNow()
    {
        if (_options is null) return; // measurer not wired until the first client render
        try
        {
            var info = BeckSvg.RenderWithInfo(_yaml, _options);
            _svg = info.Svg;
            _nodeCount = info.NodeCount;
            _edgeCount = info.EdgeCount;
            _ok = true;
            _statusText = "✓ valid";
        }
        catch (BeckYamlException ex)
        {
            _ok = false;
            _statusText = "✗ " + (ex.Line is { } n ? $"line {n}: " : "") + FirstLine(ex.Message);
        }
        catch (Exception ex)
        {
            _ok = false;
            _statusText = "✗ " + FirstLine(ex.Message);
        }
    }

    private static string FirstLine(string s)
    {
        var nl = s.IndexOf('\n');
        return nl < 0 ? s : s[..nl];
    }

    // ---- dropdowns ----------------------------------------------------------
    private void ToggleExamples() => _open = _open == Dd.Examples ? Dd.None : Dd.Examples;
    private void ToggleStyle() => _open = _open == Dd.Style ? Dd.None : Dd.Style;
    private void ToggleScheme() => _open = _open == Dd.Scheme ? Dd.None : Dd.Scheme;
    private void CloseDropdowns() => _open = Dd.None;

    // Keyboard support for the toolbar dropdowns, matching the pre-WASM playground's
    // wireDropdown: focus stays on the trigger (Enter/Space natively toggle it), ArrowUp/
    // Down open the panel and rove real focus through the options, Enter/Space on an option
    // selects it (native button activation → @onclick), and Escape closes + refocuses the
    // trigger. Option focus is driven from JS (beckEditor.focusDd*) because the grouped list
    // has no fixed indexable refs. The fixed-height playground never page-scrolls, so the
    // arrow keys need no preventDefault — which would also have swallowed Tab off the control.
    private string? _focusDdOnRender;

    private static string RootId(Dd d) => d switch
    {
        Dd.Examples => "pg-examples",
        Dd.Style => "pg-style",
        Dd.Scheme => "pg-scheme",
        _ => "",
    };

    private async Task OnTriggerKey(KeyboardEventArgs e, Dd which)
    {
        switch (e.Key)
        {
            case "ArrowDown":
            case "ArrowUp":
                if (_open != which) { _open = which; _focusDdOnRender = RootId(which); }
                else await Js.InvokeVoidAsync("beckEditor.focusDdOption", RootId(which), e.Key == "ArrowUp" ? -1 : 1);
                break;
            case "Escape":
                _open = Dd.None;
                break;
        }
    }

    private async Task OnOptionKey(KeyboardEventArgs e, Dd which)
    {
        switch (e.Key)
        {
            case "ArrowDown":
                await Js.InvokeVoidAsync("beckEditor.focusDdOption", RootId(which), 1);
                break;
            case "ArrowUp":
                await Js.InvokeVoidAsync("beckEditor.focusDdOption", RootId(which), -1);
                break;
            case "Escape":
                _open = Dd.None;
                await Js.InvokeVoidAsync("beckEditor.focusDdTrigger", RootId(which));
                break;
        }
    }

    private async Task LoadExample(Ex ex)
    {
        _open = Dd.None;
        _exampleLabel = ex.Label;
        await Js.InvokeVoidAsync("beckEditor.focusDdTrigger", "pg-examples");
        try
        {
            // Src is a site path like "/examples/x.beck.yaml"; fetch it relative to the app
            // base so it resolves on a GitHub Pages sub-path deploy too (HttpClient.BaseAddress
            // is the app base, which already includes any sub-path prefix).
            _yaml = await Http.GetStringAsync(ex.Src.TrimStart('/'));
            // Push into Monaco (swallowing the resulting change event), then render once.
            _suppressNextChange = true;
            await _editor.SetValue(_yaml);
            RenderNow();
        }
        catch (Exception e)
        {
            _ok = false;
            _statusText = "✗ could not load example: " + FirstLine(e.Message);
        }
    }

    // The scheme is pure CSS (--beck-* overrides keyed off #pg-host[data-scheme]); setting
    // the attribute recolours the diagram — including CSS-var-driven animation packets —
    // with no re-render.
    private async Task SelectScheme(Scheme s)
    {
        _open = Dd.None;
        _scheme = s.Value;
        _schemeLabel = s.Label;
        await Js.InvokeVoidAsync("beckEditor.focusDdTrigger", "pg-scheme");
    }

    // Selecting a style sets SvgRenderOptions.Style (the site-wide default) and re-renders. A
    // diagram whose meta.style names a different style still overrides this — resolution happens
    // in BeckSvg, so we just supply the default and let precedence do the rest.
    private async Task SelectStyle(StyleChoice s)
    {
        _open = Dd.None;
        await Js.InvokeVoidAsync("beckEditor.focusDdTrigger", "pg-style");
        if (_styleName == s.Name) return;
        _styleName = s.Name;
        _styleLabel = s.Label;
        _style = s.Style;
        if (_options is not null)
        {
            _options = BuildOptions();
            RenderNow();
        }
    }

    public void Dispose()
    {
        _debounce?.Cancel();
        _debounce?.Dispose();
        _hostRef?.Dispose();
    }

    private const string InitialYaml = """
        type: architecture
        meta:
          title: Checkout flow
          direction: TB
        nodes:
          - { id: web, title: Storefront, kind: user }
          - { id: api, title: Checkout API, kind: gateway }
          - { id: pay, title: Payments }
          - { id: ledger, title: Ledger, kind: db }
        edges:
          - { from: web, to: api }
          - { from: api, to: pay }
          - { from: pay, to: ledger, label: record }
        """;

    // One place for the example list: title, one-line description, and the YAML to
    // load. Grouped by diagram type so the picker can section + pill each entry.
    private sealed record Ex(string Label, string Desc, string Src);
    private sealed record ExGroup(string Type, string Label, string Glyph, string Short, Ex[] Items);

    private static readonly ExGroup[] ExampleGroups =
    [
        new("architecture", "Architecture", "⬡", "arch", [
            new Ex("Microservices platform", "An API gateway fronting independent services", "/examples/microservices.beck.yaml"),
            new Ex("Event-driven orders", "Synchronous intake, asynchronous fulfilment", "/examples/event-driven.beck.yaml"),
            new Ex("AI agent loop", "Plan, call tools in parallel, then synthesise", "/examples/agent-loop.beck.yaml"),
            new Ex("RAG answer pipeline", "Embed a question, retrieve against it, then answer", "/examples/rag-pipeline.beck.yaml"),
            new Ex("Streaming analytics", "Clickstream ingest, windowed processing, live serving", "/examples/streaming-analytics.beck.yaml"),
            new Ex("Edge to cluster", "From the edge network down to the compute cluster", "/examples/cloud-infra.beck.yaml"),
            new Ex("Zero-trust access", "Every request authorised before it reaches a service", "/examples/zero-trust.beck.yaml"),
            new Ex("Incident response", "A metric breaches, an alert fires, on-call is paged", "/examples/incident-response.beck.yaml"),
            new Ex("Deploy pipeline", "Commit to production through CI/CD stages", "/examples/cicd.beck.yaml"),
            new Ex("Webhook delivery", "A delivery fails, then a retry succeeds — narrated by captions", "/examples/webhook-retry.beck.yaml"),
            new Ex("Nested groups", "Nested boundaries via recursive compound layout", "/examples/nested-groups.beck.yaml")
        ]),
        new("sequence", "Sequence", "▷", "seq", [
            new Ex("Checkout", "Payment capture and persistence, narrated by captions", "/examples/checkout-sequence.beck.yaml"),
            new Ex("OAuth login", "Authorization-code flow with PKCE", "/examples/oauth-login.beck.yaml")
        ]),
        new("state", "State", "◈", "state", [
            new Ex("Order lifecycle", "Placed through to delivered, narrated by captions", "/examples/order-lifecycle.beck.yaml"),
            new Ex("Circuit breaker", "Closed, open and half-open transitions", "/examples/circuit-breaker.beck.yaml")
        ]),
        new("class", "Class", "▤", "class", [
            new Ex("Domain model", "Entities and relations in an order domain", "/examples/domain-model.beck.yaml"),
            new Ex("Payment gateways", "A gateway interface with provider implementations", "/examples/payment-gateways.beck.yaml")
        ])
    ];

    private sealed record Scheme(string Value, string Label);
    private static readonly Scheme[] Schemes =
    [
        new("default", "Default"),
        new("monokai", "Monokai"),
        new("one-dark", "One Dark"),
        new("hot-dog", "Hot Dog Stand")
    ];

    private static string Cap(string s) => s.Length == 0 ? s : char.ToUpperInvariant(s[0]) + s[1..];

    // Short plain-text descriptions (no markdown — these render as text in the panel). Keyed by
    // the built-in style name; a custom style added later simply shows no blurb. Declared before
    // Styles so it is initialised first (static field initialisers run in source order).
    private static readonly Dictionary<string, string> StyleBlurbs = new()
    {
        ["classic"] = "The default Beck look",
        ["minimal"] = "Sober flat: hairlines, no shadows, rings off",
        ["terminal"] = "Monospace, bracketed labels, square packets",
        ["blueprint"] = "Grid surface, dashed edges, dimension ticks",
        ["glow"] = "Gradient edges, soft bloom, breathing pulse",
        ["brutalist"] = "Thick strokes, hard offset shadow, stepped motion",
        ["sketch"] = "Hand-drawn wobbly outlines",
        ["extrude"] = "2.5D slabs with depth faces, press-down",
        ["circuit"] = "Chip pins on nodes, via dots at bends",
    };

    // The visual styles, sourced from the engine registry so the list never drifts from the
    // built-ins (classic is first — BeckStyles.All's declaration order). Each carries a display
    // label (capitalised name) and a one-line plain-text blurb for the panel.
    private sealed record StyleChoice(string Name, string Label, string Desc, BeckStyle Style);
    private static readonly StyleChoice[] Styles =
        BeckStyles.All.Select(s => new StyleChoice(s.Name, Cap(s.Name), StyleBlurbs.GetValueOrDefault(s.Name, ""), s)).ToArray();
}
