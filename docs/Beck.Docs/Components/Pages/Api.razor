@page "/api"

<PageTitle>API reference — Beck</PageTitle>

<div class="docs-shell" style="max-width:1180px;grid-template-columns:250px 1fr;">
    <aside class="sidebar">
        <div class="sidebar-label" style="text-transform:none;">Beck.Authoring</div>
        <div class="api-symbols">
            <a class="symbol-link active" href="#diagrambuilder">DiagramBuilder</a>
            <a class="symbol-link" href="#nodebuilder">NodeBuilder</a>
            <a class="symbol-link" href="#edgebuilder">EdgeBuilder</a>
            <a class="symbol-link" href="#groupbuilder">GroupBuilder</a>
            <a class="symbol-link" href="#flowbuilder">FlowBuilder</a>
        </div>
        <div class="sidebar-label" style="text-transform:none;">Beck (client)</div>
        <div class="api-symbols">
            <a class="symbol-link" href="#beckassets">BeckAssets</a>
            <span class="symbol-link">&lt;beck-diagram&gt;</span>
        </div>
    </aside>

    <article class="docs-article" style="max-width:760px;">
        <div class="breadcrumb">API <span class="sep">/</span> Beck.Authoring <span class="sep">/</span> DiagramBuilder</div>
        <div id="diagrambuilder" style="display:flex;align-items:center;gap:11px;margin-bottom:12px;">
            <span class="badge-kind">class</span>
            <h1 class="api-h1">DiagramBuilder</h1>
        </div>
        <p style="font-size:16px;line-height:1.65;color:var(--text-soft);margin:0 0 14px;">
            A dependency-free fluent builder that turns code into Beck YAML — or a fenced
            <span class="mono" style="font-size:13.5px;color:var(--text);">```beck</span> Markdown block.
            Walk any model (an Aspire app graph, an EF model, a service registry) into one and
            emit a diagram.
        </p>
        <div class="mono" style="font-size:12.5px;color:var(--text-faint);margin-bottom:34px;">namespace Beck <span style="margin:0 8px;">·</span> assembly Beck.dll</div>

        <h2 class="api-section-h">Methods</h2>
        <div style="margin-bottom:40px;">
            @foreach (var m in Methods)
            {
                <div class="member-card">
                    <div class="member-sig">@((MarkupString)m.Sig)</div>
                    <p>@((MarkupString)m.Doc)</p>
                </div>
            }
        </div>

        <h2 class="api-section-h">Example</h2>
        <div class="code-block">
            <div class="code-titlebar">Program.cs<span class="copy" data-copy="">copy</span></div>
            <div class="code-body"><span class="k">var</span> fence = <span class="k">new</span> DiagramBuilder(<span class="s">"Web Platform"</span>)
    .Direction(Direction.TB)
    .Node(<span class="s">"web"</span>, n => n.Title(<span class="s">"Web App"</span>).Kind(NodeKind.User))
    .Node(<span class="s">"api"</span>, <span class="s">"API Server"</span>)
    .Edge(<span class="s">"web"</span>, <span class="s">"api"</span>)
    .ToFence();   <span class="c">// drop straight into a .md file</span></div>
        </div>

        <p style="font-size:15px;color:var(--text-soft);">
            Authoring more than a snippet? The <a href="/docs/authoring-from-csharp" style="color:var(--accent-text);">Authoring from C#</a>
            guide shows the full builder driving a live diagram, with the source pulled straight
            from the compiled sample.
        </p>
    </article>
</div>

@code {
    private sealed record Member(string Sig, string Doc);

    private static readonly Member[] Methods =
    [
        new("<span class=\"kw\">DiagramBuilder</span>(<span class=\"ty\">string</span> title)",
            "Create a builder, optionally with a diagram title."),
        new("<span class=\"ty\">DiagramBuilder</span> <span class=\"nm\">Direction</span>(<span class=\"ty\">Direction</span> direction)",
            "Set the layout direction — <span class=\"mono\">TB</span> (default), <span class=\"mono\">BT</span>, <span class=\"mono\">LR</span>, or <span class=\"mono\">RL</span>."),
        new("<span class=\"ty\">DiagramBuilder</span> <span class=\"nm\">Node</span>(<span class=\"ty\">string</span> id, <span class=\"ty\">Action&lt;NodeBuilder&gt;</span> configure)",
            "Add a node and configure it — title, <span class=\"mono\">Kind</span>, <span class=\"mono\">Icon</span>, <span class=\"mono\">Accent</span>, <span class=\"mono\">Link</span>, and more."),
        new("<span class=\"ty\">DiagramBuilder</span> <span class=\"nm\">Group</span>(<span class=\"ty\">string</span> id, <span class=\"ty\">Action&lt;GroupBuilder&gt;</span> configure)",
            "Add a labelled, boxed cluster. Members may be node ids <em>or</em> other group ids — groups nest to any depth."),
        new("<span class=\"ty\">DiagramBuilder</span> <span class=\"nm\">Edge</span>(<span class=\"ty\">string</span> from, <span class=\"ty\">string</span> to, <span class=\"ty\">Action&lt;EdgeBuilder&gt;</span> configure)",
            "Connect two nodes (or groups). Configure label, style, curve, <span class=\"mono\">Kind</span>, color, and arrowheads."),
        new("<span class=\"ty\">DiagramBuilder</span> <span class=\"nm\">Flow</span>(<span class=\"ty\">Action&lt;FlowBuilder&gt;</span> configure)",
            "Script the animation: packets, status pills, pulses, working/idle, fail beats, and parallel steps. Omit it and Beck auto-derives a flow from the edges."),
        new("<span class=\"ty\">string</span> <span class=\"nm\">ToYaml</span>()",
            "Render the diagram as Beck YAML."),
        new("<span class=\"ty\">string</span> <span class=\"nm\">ToFence</span>()",
            "Render as a fenced <span class=\"mono\">```beck</span> Markdown block — the client renders it on any page."),
    ];
}
