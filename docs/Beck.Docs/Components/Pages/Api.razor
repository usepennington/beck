@page "/api"

<PageTitle>API reference — Beck</PageTitle>

@* Radio-input tab plumbing for the overview: pure CSS, no client JS. The checked input's
   position selects the matching label and panel. *@
<style>
    .api-tabs > input { position: absolute; opacity: 0; pointer-events: none; }
    .api-tabs .api-tab-panel { display: none; }
    .api-tabs > input:nth-of-type(1):checked ~ .api-tab-panels .api-tab-panel:nth-of-type(1),
    .api-tabs > input:nth-of-type(2):checked ~ .api-tab-panels .api-tab-panel:nth-of-type(2),
    .api-tabs > input:nth-of-type(3):checked ~ .api-tab-panels .api-tab-panel:nth-of-type(3),
    .api-tabs > input:nth-of-type(4):checked ~ .api-tab-panels .api-tab-panel:nth-of-type(4) { display: flex; }
    .api-tabs .api-tab-label { cursor: pointer; opacity: 0.55; border-bottom: 2px solid transparent; margin-bottom: -1px; }
    .api-tabs .api-tab-label:hover { opacity: 0.8; }
    .api-tabs > input:nth-of-type(1):checked ~ .api-tab-labels .api-tab-label:nth-of-type(1),
    .api-tabs > input:nth-of-type(2):checked ~ .api-tab-labels .api-tab-label:nth-of-type(2),
    .api-tabs > input:nth-of-type(3):checked ~ .api-tab-labels .api-tab-label:nth-of-type(3),
    .api-tabs > input:nth-of-type(4):checked ~ .api-tab-labels .api-tab-label:nth-of-type(4) { opacity: 1; border-bottom-color: currentColor; }
</style>

@* The entire page is generated: members, signatures, prose, and the builder-role grouping come
   from reflection over the authoring builders joined with their Beck.xml doc comments
   (ApiCatalog), and each hero diagram is Beck rendering its own API via ClassDiagramBuilder.
   Nothing here to keep in sync. *@
<div class="mx-auto max-w-6xl grid grid-cols-[250px_1fr] gap-12 items-start max-lg:grid-cols-1">
    <aside class="sticky top-16 self-start max-h-[calc(100vh-4rem)] overflow-y-auto py-8 max-lg:hidden">
        <nav id="api-nav">
            <div class="font-mono text-xs tracking-widest text-base-400 dark:text-base-500 mb-3 ml-2.5">Beck.Authoring</div>
            <div class="flex flex-col gap-px mb-5">
                <a class="api-nav-link" href="/api/#overview">Overview</a>
                @foreach (var c in ApiCatalog.Classes)
                {
                    <a class="api-nav-link" href="/api/#@c.Id">@c.Name</a>
                }
            </div>
        </nav>
    </aside>

    <article class="min-w-0 py-8 pb-24">
        @* Overview: a quick orientation plus the whole builder family on one Beck-rendered map —
           every card links to its section, every edge is a real callback collaboration. *@
        <section id="overview" class="mb-20">
            <header class="dot-grid rounded-2xl border border-base-200 dark:border-base-800 px-8 pt-6 pb-7">
                <div class="font-mono text-xs text-base-400 dark:text-base-500 mb-5">API <span class="mx-1.5">/</span> Beck.Authoring</div>
                <div class="flex items-center gap-4 mb-3">
                    <span class="font-mono text-xs uppercase tracking-wider text-primary-700 dark:text-primary-400 border border-primary-600 dark:border-primary-500 rounded-md px-2 py-0.5">namespace</span>
                    <h1 class="font-mono text-3xl font-semibold tracking-tight text-base-900 dark:text-base-50">Beck.Authoring</h1>
                </div>
                <p class="text-sm text-base-600 dark:text-base-400 m-0 mb-3.5 max-w-2xl">
                    A fluent, dependency-free API that emits Beck YAML from code. Every diagram starts at one of
                    the four root builders — one per diagram type — and ends with <span class="font-mono">ToYaml()</span>
                    or a fenced <span class="font-mono">ToFence()</span> block. You never construct the rest of the
                    family yourself: each builder arrives inside a configure callback, chains its setters, and hands
                    control back. Each tab below maps one diagram type's family — which method opens which
                    builder — and every card links to its reference.
                </p>
                @* CSS-only tabs (radio inputs), keeping the page free of client JavaScript. *@
                <div class="api-tabs mt-5">
                    @for (var i = 0; i < ApiCatalog.OverviewTabs.Count; i++)
                    {
                        <input type="radio" name="api-overview-tab" id="api-tab-@i" checked="@(i == 0)" />
                    }
                    <div class="api-tab-labels flex gap-4 border-b border-base-200 dark:border-base-800 mb-6">
                        @for (var i = 0; i < ApiCatalog.OverviewTabs.Count; i++)
                        {
                            <label class="api-tab-label font-mono text-xs tracking-wider text-primary-700 dark:text-primary-400 px-1 pb-2" for="api-tab-@i">@ApiCatalog.OverviewTabs[i].Label</label>
                        }
                    </div>
                    <div class="api-tab-panels">
                        @foreach (var t in ApiCatalog.OverviewTabs)
                        {
                            <div class="api-tab-panel justify-center">
                                <BeckDiagram Yaml="@t.Yaml" Class="beck-embed beck-embed--bare w-full" />
                            </div>
                        }
                    </div>
                </div>
            </header>
        </section>

        @foreach (var c in ApiCatalog.Classes)
        {
            <section id="@c.Id" class="mb-20">
                @* Hero band: the class diagram is part of the title composition, sitting directly
                   on the dot-grid surface rather than boxed off to the side. *@
                <header class="dot-grid rounded-2xl border border-base-200 dark:border-base-800 px-8 pt-6 pb-7 mb-8">
                    <div class="font-mono text-xs text-base-400 dark:text-base-500 mb-5">API <span class="mx-1.5">/</span> @((MarkupString)c.BreadcrumbHtml)</div>
                    <div class="grid grid-cols-[minmax(0,4fr)_minmax(0,5fr)] gap-10 items-center max-md:grid-cols-1">
                        <div>
                            <div class="flex items-center gap-4 mb-3">
                                <span class="font-mono text-xs uppercase tracking-wider text-primary-700 dark:text-primary-400 border border-primary-600 dark:border-primary-500 rounded-md px-2 py-0.5">class</span>
                                <h1 class="font-mono text-3xl font-semibold tracking-tight text-base-900 dark:text-base-50">@c.Name</h1>
                            </div>
                            <p class="text-sm text-base-600 dark:text-base-400 m-0 mb-3.5">@((MarkupString)c.SummaryHtml)</p>
                            <div class="font-mono text-xs text-base-400 dark:text-base-500">@((MarkupString)c.MetaHtml)</div>
                        </div>
                        <div class="flex items-center justify-center max-md:hidden">
                            <BeckDiagram Yaml="@c.DiagramYaml" Class="beck-embed beck-embed--bare w-full" />
                        </div>
                    </div>
                </header>

                <div class="max-w-full">
                    @foreach (var g in c.MemberGroups)
                    {
                        <div class="flex items-baseline gap-3 mt-8 mb-3">
                            <span class="font-mono text-xs font-semibold tracking-widest text-primary-700 dark:text-primary-400">@(c.MemberGroups.Count == 1 ? "METHODS" : g.Label)</span>
                            <span class="text-xs text-base-400 dark:text-base-500">@g.Hint</span>
                            <span class="flex-1 self-center border-t border-base-200 dark:border-base-800"></span>
                        </div>
                        @foreach (var m in g.Members)
                        {
                            <div class="border border-base-200 dark:border-base-800 rounded-xl overflow-hidden bg-white dark:bg-base-900/75 mb-4">
                                <div class="flex items-start gap-3 px-4 py-4 bg-base-50 dark:bg-base-900 @(m.DocHtml.Length > 0 ? "border-b border-base-200 dark:border-base-800" : "")">
                                    <div class="flex-1 min-w-0 font-mono text-xs overflow-x-auto whitespace-pre">@((MarkupString)m.SigHtml)</div>

                                </div>
                                @if (m.DocHtml.Length > 0)
                                {
                                    <p class="m-0 px-4 py-2 text-sm leading-snug text-base-600 dark:text-base-400">@((MarkupString)m.DocHtml)</p>
                                }
                            </div>
                        }
                    }

                    @if (c.ExampleHtml is not null)
                    {
                        <h2 class="text-sm font-mono uppercase tracking-wider text-base-400 dark:text-base-500 font-medium mb-4 mt-9 pb-2 border-b border-base-200 dark:border-base-800">Example</h2>
                        <div class="border border-base-200 dark:border-base-800 rounded-lg overflow-hidden bg-base-50 dark:bg-base-900 mb-4">
                            <div class="flex items-center px-3 py-2 border-b border-base-200 dark:border-base-800 font-mono text-xs text-base-400 dark:text-base-500">@c.ExampleFile<span class="ml-auto cursor-pointer" data-copy="">copy</span></div>
                            <div class="px-4 py-3 font-mono text-sm leading-relaxed whitespace-pre overflow-auto text-base-900 dark:text-base-50">@((MarkupString)c.ExampleHtml)</div>
                        </div>
                    }
                </div>
            </section>
        }
    </article>
</div>
