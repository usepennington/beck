@page "/{*Path}"
@inject IPageResolver Resolver
@inject NavigationManager Nav
@inject IEnumerable<IContentService> ContentServices

@if (_html is not null)
{
    <PageTitle>@_title — Beck</PageTitle>
    @* og:title/og:description + meta description. Pennington itself contributes the
       og:image/twitter tags for these markdown pages (SocialCardHeadContributor). *@
    <SocialMeta Title="@($"{_title} — Beck")" Description="@_description" />
    <div class="mx-auto max-w-[1240px] px-8 grid grid-cols-[230px_1fr] gap-x-12 items-start max-lg:grid-cols-1">
        <Sidebar />
        <article class="py-[34px] pb-[90px] min-w-0 max-w-[760px]">
            <div class="font-mono text-xs text-base-400 dark:text-base-500 mb-4">
                <a href="@_areaHref" class="text-base-400 dark:text-base-500 hover:text-base-600 dark:hover:text-base-400">@_areaLabel</a>
                <span class="mx-1.5">/</span>@_title
            </div>
            <div class="prose dark:prose-invert max-w-none">
                <h1>@_title</h1>
                @((MarkupString)_html)
            </div>

            @if (_prev is not null || _next is not null)
            {
                <div class="grid grid-cols-2 gap-4 mt-12 max-sm:grid-cols-1">
                    @if (_prev is not null)
                    {
                        <a class="block border border-base-200 dark:border-base-800 rounded-[11px] p-[18px] bg-white dark:bg-base-900 hover:border-base-300 dark:hover:border-base-700" href="@_prev.Url">
                            <div class="font-mono text-[11px] text-base-400 dark:text-base-500 mb-1.5">← PREVIOUS</div>
                            <div class="text-base font-semibold text-base-900 dark:text-base-50 mb-1">@_prev.Title</div>
                            <div class="text-[13.5px] text-base-600 dark:text-base-400">@_prev.Description</div>
                        </a>
                    }
                    else { <span></span> }
                    @if (_next is not null)
                    {
                        <a class="block border border-base-200 dark:border-base-800 rounded-[11px] p-[18px] bg-white dark:bg-base-900 hover:border-base-300 dark:hover:border-base-700 @(_prev is null ? "col-start-2" : "")" href="@_next.Url">
                            <div class="font-mono text-[11px] text-base-400 dark:text-base-500 mb-1.5">NEXT →</div>
                            <div class="text-base font-semibold text-base-900 dark:text-base-50 mb-1">@_next.Title</div>
                            <div class="text-[13.5px] text-base-600 dark:text-base-400">@_next.Description</div>
                        </a>
                    }
                </div>
            }
        </article>
    </div>
}
else
{
    <PageTitle>Not found — Beck</PageTitle>
    <section class="mx-auto max-w-[1240px] px-8 py-20 text-center">
        <div class="font-mono text-xs uppercase tracking-[0.15em] text-primary-700 dark:text-primary-400">404</div>
        <h1 class="text-4xl font-semibold mb-3 text-base-900 dark:text-base-50">Page not found</h1>
        <p class="text-base-600 dark:text-base-400">No content matches <span class="font-mono">@Path</span>. <a class="font-mono text-primary-700 dark:text-primary-400" href="/">Back home →</a></p>
    </section>
}

@code {
    [Parameter] public string? Path { get; set; }

    private sealed record Neighbor(string Title, string Url, string? Description);

    private string? _title;
    private string? _description;
    private string? _html;
    private string _areaLabel = "Docs";
    private string _areaHref = "/docs/";
    private Neighbor? _prev;
    private Neighbor? _next;

    protected override async Task OnInitializedAsync()
    {
        var requested = new UrlPath(Path ?? string.Empty).EnsureLeadingSlash();

        if (await Resolver.ResolveAsync(requested) is not { } page)
        {
            return;
        }

        _title = page.Metadata.Title;
        _description = page.Metadata.Description;
        _html = page.Content.Html;

        var path = requested.Value;
        var area = AreaOf(path);
        _areaHref = area + "/";
        _areaLabel = AreaLabels.TryGetValue(area, out var lbl) ? lbl : Title(area.Trim('/'));

        // Build prev/next from the ordered area page list.
        var all = new List<ContentTocItem>();
        foreach (var svc in ContentServices)
        {
            all.AddRange(await svc.GetContentTocEntriesAsync());
        }
        var ordered = all
            .Where(i => !i.SearchOnly && InArea(i.Route.CanonicalPath.Value, area))
            .OrderBy(i => i.Order).ThenBy(i => i.Title)
            .ToList();

        var idx = ordered.FindIndex(i => new UrlPath(i.Route.CanonicalPath.Value).Matches(requested));
        if (idx > 0)
        {
            var p = ordered[idx - 1];
            _prev = new Neighbor(p.Title, p.Route.CanonicalPath.Value, p.Description);
        }
        if (idx >= 0 && idx < ordered.Count - 1)
        {
            var n = ordered[idx + 1];
            _next = new Neighbor(n.Title, n.Route.CanonicalPath.Value, n.Description);
        }
    }

    private static readonly Dictionary<string, string> AreaLabels = new()
    {
        ["/docs"] = "Docs",
    };

    private static string AreaOf(string path)
    {
        var parts = path.Trim('/').Split('/', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length > 0 ? "/" + parts[0] : "/";
    }

    private static bool InArea(string route, string area)
    {
        var r = route.TrimEnd('/');
        if (r.Length == 0) r = "/";
        return string.Equals(r, area, StringComparison.OrdinalIgnoreCase)
            || r.StartsWith(area + "/", StringComparison.OrdinalIgnoreCase);
    }

    private static string Title(string s) =>
        string.IsNullOrEmpty(s) ? s : char.ToUpperInvariant(s[0]) + s[1..].Replace('-', ' ');
}
