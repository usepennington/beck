        // ---- Sequence diagrams ----
        new("Sequence diagram", "type: sequence", "sequence",
            "participants are columns; messages are rows, in authored order. The message order is the animation.",
            "type: sequence\nparticipants:\n  - { id: web, kind: user }\n  - { id: api }\nmessages:\n  - { from: web, to: api,\n      label: POST /orders }",
            "participants: [ { id: web, title: Web, kind: user }, { id: api, title: API } ]\nmessages:\n  - { from: web, to: api, label: POST /orders }\n  - { from: api, to: web, label: 201, reply: true }",
            "sequence"),

        new("Reply & activation", "messages", "sequence",
            "reply: true draws a dashed return with an open arrowhead and closes the receiver's activation bar.",
            "messages:\n  - { from: api, to: db,\n      label: INSERT }\n  - { from: db, to: api,\n      label: ok, reply: true }",
