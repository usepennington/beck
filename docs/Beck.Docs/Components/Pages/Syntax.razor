            "sequence"),

        new("Self-message & section", "messages", "sequence",
            "A message to yourself draws a loop; a - section: entry inserts a labelled band.",
            "messages:\n  - { from: api, to: api,\n      label: validate }\n  - section: Payment",
            "participants: [ { id: api, title: API }, { id: pay, title: Payments, icon: lock, accent: info } ]\nmessages:\n  - { from: api, to: api, label: validate }\n  - section: Payment\n  - { from: api, to: pay, label: capture }\n  - { from: pay, to: api, label: ok, reply: true }",
            "sequence"),

        new("Async message", "messages", "sequence",
            "kind: async renders dashed with an open arrowhead and slow, eased packet motion — fire-and-forget events.",
            "messages:\n  - { from: api, to: bus,\n      label: OrderPlaced,\n      kind: async }",
            "participants: [ { id: api, title: API }, { id: bus, title: Event Bus, kind: queue } ]\nmessages:\n  - { from: api, to: bus, label: OrderPlaced, kind: async }",
            "sequence"),

        // ---- State diagrams ----
        new("State diagram", "type: state", "state",
            "transitions auto-create their states; \"[*]\" is the entry dot / exit bullseye.",
            "type: state\ntransitions:\n  - { from: \"[*]\", to: draft }\n  - { from: draft, to: live,\n      label: publish }",
            "meta: { direction: LR }\ntransitions:\n  - { from: \"[*]\", to: draft }\n  - { from: draft, to: live, label: publish }\n  - { from: live, to: \"[*]\" }",
            "state"),

        new("Refined states", "states", "state",
            "Declare a state only to refine it — a title, an accent, a subtitle.",
            "states:\n  - { id: review,\n      title: In Review,\n      accent: warn }",
            "meta: { direction: LR }\nstates:\n  - { id: review, title: In Review, accent: warn }\ntransitions:\n  - { from: \"[*]\", to: draft }\n  - { from: draft, to: review, label: submit }\n  - { from: review, to: draft, label: reject }",
            "state"),

        new("Self-transition", "transitions", "state",
            "A transition from a state to itself draws a compact loop — retries, heartbeats, re-entrant states.",
            "transitions:\n  - { from: retrying, to: retrying,\n      label: backoff }",
            "meta: { direction: LR }\nstates:\n  - { id: retrying, title: Retrying, accent: warn }\ntransitions:\n  - { from: \"[*]\", to: calling }\n  - { from: calling, to: retrying, label: error }\n  - { from: retrying, to: retrying, label: backoff }\n  - { from: retrying, to: calling, label: retry }",
            "state"),

        // ---- Class diagrams ----
        new("Class diagram", "type: class", "class",
            "Classes are cards with «stereotype», fields, and methods compartments.",
            "type: class\nclasses:\n  - id: order\n    name: Order\n    fields: [\"Total: Money\"]\n    methods: [\"Submit()\"]",
            "classes:\n  - { id: order, name: Order, stereotype: aggregate, fields: [\"Status: OrderStatus\", \"Total: Money\"], methods: [\"Submit()\"] }",
            "class"),

        new("Inheritance & composition", "relations", "class",
