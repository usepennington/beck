@using Beck.Rendering
@* Markdown-embedded icon reference: `<IconGallery />`. Rendered server-side from the C# engine's
   built-in icon registry (BeckSvg.IconRegistry), so the page can never drift from the shipped set.
   Keys that share identical svg are aliases and collapse onto one card. *@

<div class="not-prose my-7" data-beck-icon-gallery data-count="@_groups.Count">
    @foreach (var g in _groups)
    {
        <div class="beck-icon-card">
            <span class="beck-icon-card-chip" aria-hidden="true">@((MarkupString)g.Svg)</span>
            <code class="beck-icon-key">@g.Keys[0]</code>
            @if (g.Keys.Count > 1)
            {
                <span class="beck-icon-aliases">@string.Join(" · ", g.Keys.Skip(1))</span>
            }
        </div>
    }
</div>

@code {
    private sealed record IconGroup(string Svg, List<string> Keys);

    // Group the registry by identical svg markup (aliases like db/database share a glyph),
    // preserving the registry's insertion order — it's roughly category-grouped.
    private static readonly List<IconGroup> _groups = BuildGroups();

    private static List<IconGroup> BuildGroups()
    {
        var groups = new List<IconGroup>();
        var bySvg = new Dictionary<string, int>(StringComparer.Ordinal);
        foreach (var (key, svg) in BeckSvg.IconRegistry)
        {
            if (bySvg.TryGetValue(svg, out int i))
            {
                groups[i].Keys.Add(key);
            }
            else
            {
                bySvg[svg] = groups.Count;
                groups.Add(new IconGroup(svg, [key]));
            }
        }
        return groups;
    }
}
