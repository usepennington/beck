@* Markdown-embedded, reflection-driven token gallery: `<BeckGallery Of="eases" />`.
   Enumerates a Beck token enum, pulls each value's source doc comment, and renders a live
   preview of every value. Each preview is a ```beck fence (`code.language-beck`) the client
   hydrates into a light-DOM diagram — the same path the syntax cheatsheet uses, so the host
   palette and dark mode reach it for free. *@

@if (_items is null)
{
    <p class="not-prose my-4 font-mono text-sm text-base-500 dark:text-base-400">
        Unknown gallery <code>Of="@Of"</code>.
    </p>
}
else
{
    <div class="not-prose my-7 grid gap-4 grid-cols-[repeat(auto-fill,minmax(240px,1fr))]">
        @foreach (var item in _items)
        {
            <div class="flex flex-col overflow-hidden rounded-xl border border-base-200 bg-white dark:border-base-800 dark:bg-base-900">
                <div class="flex items-center gap-2 px-3.5 pt-3">
                    <span class="text-sm font-semibold text-base-900 dark:text-base-50">@item.Name</span>
                    <span class="ml-auto rounded border border-base-200 px-[7px] py-px font-mono text-[10.5px] text-base-500 dark:border-base-700 dark:text-base-400">@item.Token</span>
                </div>
                @if (!string.IsNullOrEmpty(item.Summary))
                {
                    <p class="m-0 px-3.5 pt-1.5 text-[12.5px] leading-snug text-base-600 dark:text-base-400">@item.Summary</p>
                }
                <div class="syntax-canvas dot-grid mt-3 flex flex-1 min-h-[132px] items-center justify-center overflow-auto border-t border-base-200 px-3 py-4 dark:border-base-800"><pre><code class="language-beck">@item.Yaml</code></pre></div>
            </div>
        }
    </div>
}

@code {
    /// <summary>Which token enum to render — e.g. <c>node-kinds</c>, <c>edge-kinds</c>, <c>eases</c>.</summary>
    [Parameter] public string? Of { get; set; }

    private IReadOnlyList<GalleryItem>? _items;

    protected override void OnParametersSet() =>
        _items = GalleryCatalog.Build((Of ?? string.Empty).Trim().ToLowerInvariant());
}
