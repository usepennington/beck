<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>preview</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Beck.Docs</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- The Beck engine RCL: ships _content/Beck/beck.global.js as a static web asset
         and the Beck.Authoring DiagramBuilder C# API used by the API docs. -->
    <ProjectReference Include="..\..\dotnet\Beck\Beck.csproj" />
    <!-- Pennington content engine (bare host) + tree-sitter :symbol source embeds. -->
    <ProjectReference Include="..\..\..\penn\src\Pennington\Pennington.csproj" />
    <ProjectReference Include="..\..\..\penn\src\Pennington.TreeSitter\Pennington.TreeSitter.csproj" />
    <!-- MonorailCSS: runtime utility-class discovery + the /styles.css endpoint. The
         semantic primary/accent/base palette also feeds the embedded Beck engine via
         the emitted color CSS variables. -->
    <ProjectReference Include="..\..\..\penn\src\Pennington.MonorailCss\Pennington.MonorailCss.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Watch Include="Content\**\*.*" />
    <Watch Include="Components\**\*.razor" />
    <Watch Include="wwwroot\**\*.*" />
  </ItemGroup>
</Project>
